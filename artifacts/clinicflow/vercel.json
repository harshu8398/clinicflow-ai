{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR-RENDER-BACKEND-URL/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://YOUR-RENDER-BACKEND-URL/uploads/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
